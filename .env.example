# Convex
CONVEX_DEPLOYMENT_URL=
NEXT_PUBLIC_CONVEX_URL=

# Anthropic (routed through Respan gateway — set base URL in code)
ANTHROPIC_API_KEY=

# Respan (LLM observability gateway)
RESPAN_API_KEY=
RESPAN_BASE_URL=https://api.respan.ai/v1

# Photon / Spectrum (iMessage delivery) — optional, only used if PHOTON_API_KEY is set
PHOTON_API_KEY=
PHOTON_TARGET_NUMBER=

# AppleScript iMessage fallback (runs on the Mac via Next.js route /api/deliver)
# E.164 phone number like +14155551234
IMESSAGE_TARGET_NUMBER=
NEXT_PUBLIC_IMESSAGE_TARGET_NUMBER=

# Google APIs (Gmail draft + Calendar event in executeTask)
# Mint via OAuth Playground with scopes: gmail.compose, calendar.events
GOOGLE_ACCESS_TOKEN=

# OpenAI Whisper (audio file transcription for watch-recorded clips)
OPENAI_API_KEY=

# Notion mirror — structured tasks get written to this database
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Hammerspoon polling endpoint — Convex HTTP actions URL
# (npx convex dev writes NEXT_PUBLIC_CONVEX_SITE_URL automatically)
NEXT_PUBLIC_CONVEX_SITE_URL=
